{
  "name": "attest",
  "version": "1.0.0",
  "description": "Evidence-cited audit agent: tests control attributes against evidence samples and produces auditable assessments",
  "type": "module",
  "private": true,
  "engines": {
    "node": ">=20.12"
  },
  "scripts": {
    "audit": "tsx src/cli.ts",
    "eval": "tsx src/eval/run.ts",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "lint": "eslint src test",
    "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.ts\" \"test/**/*.ts\""
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.110.0",
    "exceljs": "^4.4.0",
    "sharp": "^0.34.4",
    "zod": "^4.1.13"
  },
  "devDependencies": {
    "@types/node": "^22.19.7",
    "eslint": "^9.39.2",
    "prettier": "^3.6.2",
    "tsx": "^4.20.3",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.46.4",
    "vitest": "^3.2.4"
  }
}
